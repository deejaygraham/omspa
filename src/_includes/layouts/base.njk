<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or "Strategies and Patterns Handbook" }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css" />
    <link rel="stylesheet" href="{{ '/assets/styles.css' | url }}" />
  </head>
  <body>
    <section class="section">
      <div class="container">
        <header class="content has-text-centered">
          <h1 class="title is-3">Strategies and Patterns Handbook</h1>
        </header>

        <main class="content">
          {{ content | safe }}
        </main>

        <footer class="content has-text-centered">
          <p>Converted from the original 1997 hypertext edition. &copy; 1997 Object International, Inc. All rights reserved.</p>
          <p><small>Built {{ build.date }}</small></p>
        </footer>
      </div>
    </section>
  </body>
</html>
